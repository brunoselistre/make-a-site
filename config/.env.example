# ── Credenciais FTP do servidor (lidas pelos scripts de deploy via shell) ─────
# Copie para config/.env.production e preencha.
# ATENÇÃO: nunca commite este arquivo com valores reais.

FTP_HOST=               # ex: files.hostinger.com  (veja hPanel > Arquivos > Contas FTP)
FTP_USER=               # ex: u123456789
FTP_PASSWORD=           # senha da conta FTP — defina no hPanel > Arquivos > Contas FTP
FTP_PORT=21             # padrão FTP com TLS
REMOTE_PATH=            # ex: /home/u123456789/public_html
SITE_URL=               # ex: https://dominiodocliente.com.br
